{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=stockbot;Username=stockbot;Password=stockbot_pass"
  },
  "InfluxDb": {
    "Url": "http://localhost:8086",
    "Token": "stockbot-super-secret-token",
    "Org": "stockbot-org",
    "Bucket": "stockbot"
  },
  "MarketData": {
    "FetchIntervalMinutes": 5
  },
  "TwseApi": {
    "StockDayAllUrl": "https://openapi.twse.com.tw/v1/exchangeReport/STOCK_DAY_ALL"
  },
  "TpexApi": {
    "DailyCloseUrl": "https://www.tpex.org.tw/openapi/v1/tpex_mainboard_daily_close_quotes"
  },
  "PttCrawler": {
    "BaseUrl": "https://www.ptt.cc",
    "Board": "Stock",
    "FetchIntervalSeconds": 60,
    "ArticleFetchDelayMs": 500
  },
  "CnyesCrawler": {
    "RssUrl": "https://www.cnyes.com/rss/cat/tw_stock_news",
    "FetchIntervalSeconds": 60
  },
  "SignalAnalyzer": {
    "WindowMinutes": 15,
    "MentionDeltaThreshold": 50.0,
    "VolumeDeltaThreshold": 50.0,
    "ResonancePriceDeltaMin": 2.0,
    "BearishPriceDeltaMax": -1.0,
    "AnalysisIntervalSeconds": 900
  },
  "Telegram": {
    "BotToken": "YOUR_BOT_TOKEN_HERE",
    "ChatId": 0,
    "PollingTimeoutSeconds": 30
  }
}
